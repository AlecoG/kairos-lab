---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="mb-6 max-w-3xl">
  <h2 class="mb-2 text-[clamp(1.9rem,3vw,2.45rem)] font-black tracking-[-0.03em] text-[#111111]">{title}</h2>
  <p class="m-0 max-w-[62ch] text-[1rem] leading-relaxed text-[#6b6b6b]">{description}</p>
</div>
